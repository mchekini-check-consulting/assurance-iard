# Copier ce fichier en .env sur la VM, à côté du docker-compose.yml.
# .env ne doit jamais être commité.

# Clé OpenAI utilisée pour l'OCR des documents KYC (si absente, l'OCR est désactivé)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# Secret JWT du backend iard-client (256 bits minimum)
JWT_SECRET=change-me-with-a-very-long-random-secret-of-at-least-256-bits

# IP publique de la VM : indispensable pour que les clients Kafka externes
# (postes des stagiaires) puissent se connecter au broker sur VM:9092
KAFKA_EXTERNAL_HOST=1.2.3.4
